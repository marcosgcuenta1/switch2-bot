# Copia este archivo a ".env" y rellena tus valores.

# Token del bot de Telegram (te lo da @BotFather al crear el bot)
TELEGRAM_TOKEN=123456789:AAaaBBbbCCccDDddEEeeFFff

# Tu chat_id (el de tu cuenta). Para averiguarlo:
#   1) Escribe algo a tu bot en Telegram.
#   2) Abre en el navegador: https://api.telegram.org/bot<TU_TOKEN>/getUpdates
#   3) Copia el numero de "chat":{"id": ... }
TELEGRAM_CHAT_ID=1104050697
